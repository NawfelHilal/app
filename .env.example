DJANGO_SECRET_KEY=replace-with-at-least-32-random-characters
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
POSTGRES_DB=fleetpro
POSTGRES_USER=fleetpro
POSTGRES_PASSWORD=fleetpro
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
JWT_SIGNING_KEY=replace-with-the-same-32-character-jwt-secret
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
FIREBASE_CREDENTIALS_PATH=
REDIS_URL=redis://redis:6379/0
GPS_MATCH_RADIUS_KM=10
GPS_JWT_SECRET=replace-with-the-same-32-character-jwt-secret
CORE_API_URL=http://backend:8000/api/v1
ENABLE_DEMO_SIMULATION=true
EXPO_PUBLIC_API_URL=http://localhost:8090/api/v1
EXPO_PUBLIC_GPS_URL=http://localhost:8090
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_change_me
EXPO_PUBLIC_USE_SIMULATED_PAYMENT=true
EXPO_PUBLIC_ENABLE_DEMO_SIMULATION=true
# For a real phone, replace localhost with your PC Wi-Fi IP, for example:
# EXPO_PUBLIC_API_URL=http://192.168.1.20:8090/api/v1
# EXPO_PUBLIC_GPS_URL=http://192.168.1.20:8090
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.20
# Also add the same IP to DJANGO_ALLOWED_HOSTS when testing from a phone.

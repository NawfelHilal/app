# Local Docker stack only.
# For the current Scaleway demo, use mobile/.env instead.

DJANGO_SECRET_KEY=local-development-secret-at-least-32-characters
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,192.168.1.20

POSTGRES_DB=fleetpro
POSTGRES_USER=fleetpro
POSTGRES_PASSWORD=fleetpro
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

JWT_SIGNING_KEY=fleetpro-local-jwt-secret-at-least-32-characters
GPS_JWT_SECRET=fleetpro-local-jwt-secret-at-least-32-characters
REDIS_URL=redis://redis:6379/0
CORE_API_URL=http://backend:8000/api/v1

ENABLE_DEMO_SIMULATION=true
EXPO_PUBLIC_API_URL=http://192.168.1.20:8090/api/v1
EXPO_PUBLIC_GPS_URL=http://192.168.1.20:8090
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.20
EXPO_PUBLIC_USE_SIMULATED_PAYMENT=true
EXPO_PUBLIC_ENABLE_DEMO_SIMULATION=true
EXPO_PUBLIC_DEMO_PASSWORD=password123

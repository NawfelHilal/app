DJANGO_SECRET_KEY=replace-with-a-very-long-random-production-secret
DJANGO_DEBUG=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_ALLOWED_HOSTS=api.fleetpro.example.com,fleetpro.example.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://fleetpro.example.com

POSTGRES_DB=fleetpro
POSTGRES_USER=fleetpro
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
GPS_MATCH_RADIUS_KM=10

JWT_SIGNING_KEY=replace-with-the-same-32-plus-character-jwt-secret
GPS_JWT_SECRET=replace-with-the-same-32-plus-character-jwt-secret
CORE_API_URL=http://backend:8000/api/v1

STRIPE_SECRET_KEY=sk_live_or_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
FIREBASE_CREDENTIALS_PATH=
ENABLE_DEMO_SIMULATION=false

GUNICORN_WORKERS=3
SCALEWAY_REGISTRY=rg.fr-par.scw.cloud/fleet-pro
IMAGE_TAG=latest
HTTP_PORT=80

# Mobile build-time values, used by EAS/Expo rather than by production containers.
EXPO_PUBLIC_API_URL=https://api.fleetpro.example.com/api/v1
EXPO_PUBLIC_GPS_URL=https://api.fleetpro.example.com
